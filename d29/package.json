{
  "name": "circuit-noise-analyzer",
  "version": "1.0.0",
  "description": "Circuit Noise Analysis Desktop Application",
  "main": "electron/main.js",
  "scripts": {
    "start": "concurrently \"npm run start:react\" \"npm run start:electron\"",
    "start:react": "webpack serve --mode development",
    "start:electron": "wait-on http://localhost:3000 && electron .",
    "build": "webpack --mode production",
    "build:addon": "node-gyp rebuild",
    "package": "electron-builder"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^2.10.0",
    "bindings": "^1.5.0",
    "node-addon-api": "^7.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "@babel/preset-react": "^7.23.0",
    "babel-loader": "^9.1.3",
    "css-loader": "^6.8.1",
    "electron": "^27.0.0",
    "electron-builder": "^24.6.4",
    "concurrently": "^8.2.2",
    "wait-on": "^7.2.0",
    "html-webpack-plugin": "^5.5.3",
    "style-loader": "^3.3.3",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1",
    "node-gyp": "^10.0.1"
  },
  "build": {
    "appId": "com.circuit.noise.analyzer",
    "files": [
      "electron/**/*",
      "dist/**/*",
      "build/Release/**/*",
      "package.json"
    ]
  }
}
